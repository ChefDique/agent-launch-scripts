{
  "_comment": "Agent registry. Single source of truth for launch-agent.sh, Swarmy's AgentRemote runtime adapter, and the Electron remote. Add a new agent by appending one entry — no new bash file needed.",
  "_field_docs": {
    "id": "Stable lookup key. Used by launch-agent.sh <id>, Swarmy's agentremote_runtime.py add <id>, and the Electron remote button id.",
    "display_name": "Human-facing label. Claude runtimes pass it to -n <Name>; other runtimes use it for pane labels and AgentRemote UI.",
    "runtime": "Agent CLI runtime. Supported values: codex, claude, hermes, openclaw. Defaults to codex for missing legacy entries while Claude tokens are constrained.",
    "allow_claude_runtime": "Set true only for an intentional Claude runtime entry. Tests fail any runtime=claude entry without this explicit opt-in.",
    "model": "Optional runtime-specific model. Claude defaults to claude-opus-4-7[1m]; Codex defaults to gpt-5.3-codex.",
    "reasoning_effort": "Optional runtime-specific effort/thinking level. Claude maps to --effort; Codex maps to model_reasoning_effort; OpenClaw maps to --thinking.",
    "provider": "Optional provider for runtimes that expose one, currently Hermes.",
    "sandbox": "Optional Codex sandbox mode. Defaults to danger-full-access for Codex entries launched from this local operator HUD.",
    "approval_policy": "Optional Codex approval policy. Defaults to never for Codex entries launched from this local operator HUD.",
    "runtime_args": "Optional argv array appended to the generated runtime command for runtime-specific flags.",
    "team": "Optional runtime grouping key for Swarmy's teams layout. Agents with the same team are stacked into one balanced tmux window; omitted means default.",
    "team_id": "Alias for team when importing from ACRM/Armory-shaped records.",
    "tmux_target": "Pane title used for broadcast + status targeting. Defaults to lowercased rename_to when present, otherwise lowercased display_name. Only set explicitly to override that derivation.",
    "cwd": "Working directory the launcher cd's into before exec. Tilde-expanded by launch-agent.sh.",
    "color": "Claude-only argument to /color. Set during Claude auto-inject; ignored by Codex/Hermes/OpenClaw.",
    "theme_color": "Hex color string (e.g. '#00f2ff') used by AgentRemote to generate per-agent CSS variables at runtime. Controls the active-border glow and radial-orb palette. Picked in the Add Agent modal. Falls back to --accent if omitted.",
    "rename_to": "Claude-only argument to /rename. Non-Claude runtimes keep the tmux pane title unless tmux_target is set.",
    "startup_slash": "Startup command passed to runtimes that support it. Lead agents must use /lead-gogo so repo-local /gogo files extend the global protocol instead of shadowing it. Empty string disables.",
    "auto_restart": "If false, Swarmy's AgentRemote runtime loop exits after the agent quits instead of relooping. Default true (omit the field to mean true). Editable from the Electron remote's right-click menu.",
    "pre_launch": "Optional path to a hook script run before execing the configured runtime. Tilde-expanded. Replaces the inline telegram-cleanup blocks.",
    "env": "Optional map of env vars to export before exec (e.g. KOKORO_VOICE for the telegram-voice-followup hook).",
    "avatar": "Optional avatar SVG filename inside remote-app/assets/. Defaults to <id>.svg if unset. Used by the Electron remote button render.",
    "profile_preset": "Optional preset id from _profile_presets. Describes runtime/model/sandbox/worktree/local/skills posture before launcher-specific materialization.",
    "workspace_mode": "Optional explicit workspace posture: repo_root, repo_subpath, worktree, or resolved_external.",
    "worktree_strategy": "Optional explicit workspace isolation strategy: shared_cwd, dedicated_per_agent, existing_worktree, or none.",
    "local_mode": "Optional local runtime presentation: visible_tmux or headless.",
    "skills": "Optional skill allowlist intended for the agent profile or generated spawn brief."
  },
